generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String              @id @default(uuid())
  email                String              @unique
  passwordHash         String              @map("password_hash")
  name                 String?
  pin                  String?
  otp                  String?
  emailVerified        Boolean             @default(false) @map("email_verified")
  avatarUrl            String?             @map("avatar_url")
  createdAt            DateTime            @default(now()) @map("created_at")
  arisanParticipations ArisanParticipant[]
  arisanReceived       ArisanPeriod[]
  comments             Comment[]
  createdCommunities   Community[]         @relation("CommunityCreatedBy")
  contributions        Contribution[]
  eventsCreated        Event[]
  memberships          Membership[]
  posts                Post[]
  rsvps                Rsvp[]
  txnsCreated          Transaction[]       @relation("TxnCreatedBy")
  txnsAsActor          Transaction[]       @relation("TxnActor")
  balance              UserBalance?
  topUps               TopUp[]
  withdrawals          WithdrawalRequest[]
  eventJoinRequests    EventJoinRequest[]

  @@map("users")
}

model Community {
  id                   String              @id @default(uuid())
  name                 String
  slug                 String?             @unique
  description          String?
  logoUrl              String?             @map("logo_url")
  themeColor           String              @default("#4F46E5") @map("theme_color")
  createdById          String?             @map("created_by")
  createdAt            DateTime            @default(now()) @map("created_at")
  arisanParticipants   ArisanParticipant[]
  arisanPeriods        ArisanPeriod[]
  comments             Comment[]
  createdBy            User?               @relation("CommunityCreatedBy", fields: [createdById], references: [id])
  contributions        Contribution[]
  duesSchedules        DuesSchedule[]
  events               Event[]
  memberships          Membership[]
  paymentConfig        PaymentConfig?
  pockets              Pocket[]
  posts                Post[]
  rsvps                Rsvp[]
  transactions         Transaction[]
  eventJoinRequests    EventJoinRequest[]
  withdrawals          WithdrawalRequest[]

  @@map("communities")
}

model UserBalance {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  balance   BigInt   @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_balances")
}

model TopUp {
  id        String      @id @default(uuid())
  userId    String      @map("user_id")
  amount    BigInt
  status    TopUpStatus @default(pending)
  orderId   String      @unique @map("order_id")
  snapToken String?     @map("snap_token")
  createdAt DateTime    @default(now()) @map("created_at")
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("top_ups")
}

model WithdrawalRequest {
  id            String           @id @default(uuid())
  communityId   String?          @map("community_id")
  pocketId      String?          @map("pocket_id")
  userId        String           @map("user_id")
  amount        BigInt
  status        WithdrawalStatus @default(pending)
  bankName      String           @map("bank_name")
  accountNumber String           @map("account_number")
  accountHolder String           @map("account_holder")
  note          String?
  processedAt   DateTime?        @map("processed_at")
  createdAt     DateTime         @default(now()) @map("created_at")
  community     Community?       @relation(fields: [communityId], references: [id], onDelete: Cascade)
  pocket        Pocket?          @relation(fields: [pocketId], references: [id], onDelete: Cascade)
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([pocketId])
  @@index([userId])
  @@map("withdrawal_requests")
}


model PaymentConfig {
  id                 String           @id @default(uuid())
  communityId        String           @unique @map("community_id")
  method             PaymentMethod    @default(manual_transfer)
  bankName           String?          @map("bank_name")
  accountNumber      String?          @map("account_number")
  accountHolder      String?          @map("account_holder")
  gatewayProvider    PaymentProvider? @map("gateway_provider")
  gatewayMerchantId  String?          @map("gateway_merchant_id")
  gatewayCredentials String?          @map("gateway_credentials")
  isActive           Boolean          @default(true) @map("is_active")
  createdAt          DateTime         @default(now()) @map("created_at")
  updatedAt          DateTime         @updatedAt @map("updated_at")
  community          Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@map("payment_configs")
}

model Membership {
  id          String           @id @default(uuid())
  communityId String           @map("community_id")
  userId      String           @map("user_id")
  role        UserRole         @default(member)
  status      MembershipStatus @default(active)
  joinedAt    DateTime         @default(now()) @map("joined_at")
  community   Community        @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@map("memberships")
}

model Pocket {
  id                 String              @id @default(uuid())
  communityId        String              @map("community_id")
  name               String
  description        String?
  type               PocketType          @default(KAS)
  balance            BigInt              @default(0)
  vaNumber           String?             @map("va_number")
  vaName             String?             @map("va_name")
  contributionAmount Int?                @map("contribution_amount")
  createdAt          DateTime            @default(now()) @map("created_at")
  arisanParticipants ArisanParticipant[]
  arisanPeriods      ArisanPeriod[]
  duesSchedules      DuesSchedule[]
  community          Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  transactions       Transaction[]
  withdrawals        WithdrawalRequest[]

  @@index([communityId])
  @@map("pockets")
}

model Transaction {
  id            String         @id @default(uuid())
  communityId   String         @map("community_id")
  pocketId      String         @map("pocket_id")
  memberId      String?        @map("member_id")
  amount        BigInt
  direction     TxnDirection
  category      String?
  note          String?
  status        TxnStatus      @default(confirmed)
  createdById   String?        @map("created_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  contributions Contribution[]
  community     Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdBy     User?          @relation("TxnCreatedBy", fields: [createdById], references: [id])
  member        User?          @relation("TxnActor", fields: [memberId], references: [id])
  pocket        Pocket         @relation(fields: [pocketId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@index([pocketId])
  @@index([memberId])
  @@map("transactions")
}

model DuesSchedule {
  id            String         @id @default(uuid())
  communityId   String         @map("community_id")
  pocketId      String         @map("pocket_id")
  title         String
  amount        BigInt
  period        String         @default("monthly")
  dueDate       DateTime?      @map("due_date")
  createdAt     DateTime       @default(now()) @map("created_at")
  contributions Contribution[]
  community     Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  pocket        Pocket         @relation(fields: [pocketId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@map("dues_schedules")
}

model ArisanParticipant {
  id          String    @id @default(uuid())
  communityId String    @map("community_id")
  pocketId    String    @map("pocket_id")
  memberId    String    @map("member_id")
  joinOrder   Int?      @map("join_order")
  hasReceived Boolean   @default(false) @map("has_received")
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  member      User      @relation(fields: [memberId], references: [id])
  pocket      Pocket    @relation(fields: [pocketId], references: [id], onDelete: Cascade)

  @@unique([pocketId, memberId])
  @@map("arisan_participants")
}

model ArisanPeriod {
  id                String         @id @default(uuid())
  communityId       String         @map("community_id")
  pocketId          String         @map("pocket_id")
  roundNo           Int            @map("round_no")
  periodDate        DateTime?      @map("period_date")
  recipientMemberId String?        @map("recipient_member_id")
  status            ArisanStatus   @default(open)
  createdAt         DateTime       @default(now()) @map("created_at")
  community         Community      @relation(fields: [communityId], references: [id], onDelete: Cascade)
  pocket            Pocket         @relation(fields: [pocketId], references: [id], onDelete: Cascade)
  recipient         User?          @relation(fields: [recipientMemberId], references: [id])
  contributions     Contribution[]

  @@unique([pocketId, roundNo])
  @@index([pocketId])
  @@map("arisan_periods")
}

model Contribution {
  id             String             @id @default(uuid())
  communityId    String             @map("community_id")
  scheduleId     String?            @map("schedule_id")
  arisanPeriodId String?            @map("arisan_period_id")
  memberId       String             @map("member_id")
  amount         BigInt
  status         ContributionStatus @default(unpaid)
  proofUrl       String?            @map("proof_url")
  paidAt         DateTime?          @map("paid_at")
  transactionId  String?            @map("transaction_id")
  createdAt      DateTime           @default(now()) @map("created_at")
  arisanPeriod   ArisanPeriod?      @relation(fields: [arisanPeriodId], references: [id], onDelete: Cascade)
  community      Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  member         User               @relation(fields: [memberId], references: [id])
  schedule       DuesSchedule?      @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  transaction    Transaction?       @relation(fields: [transactionId], references: [id])

  @@index([communityId])
  @@index([memberId])
  @@index([scheduleId])
  @@map("contributions")
}

model Post {
  id             String    @id @default(uuid())
  communityId    String    @map("community_id")
  authorId       String    @map("author_id")
  body           String
  isAnnouncement Boolean   @default(false) @map("is_announcement")
  createdAt      DateTime  @default(now()) @map("created_at")
  comments       Comment[]
  author         User      @relation(fields: [authorId], references: [id])
  community      Community @relation(fields: [communityId], references: [id], onDelete: Cascade)

  @@index([communityId])
  @@map("posts")
}

model Comment {
  id          String    @id @default(uuid())
  communityId String    @map("community_id")
  postId      String    @map("post_id")
  authorId    String    @map("author_id")
  body        String
  createdAt   DateTime  @default(now()) @map("created_at")
  author      User      @relation(fields: [authorId], references: [id])
  community   Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  post        Post      @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("comments")
}

model Event {
  id           String             @id @default(uuid())
  communityId  String             @map("community_id")
  title        String
  location     String?
  eventDate    DateTime?          @map("event_date")
  description  String?
  imageUrl     String?            @map("image_url")
  price        BigInt?
  isPublic     Boolean            @default(false) @map("is_public")
  createdById  String?            @map("created_by")
  createdAt    DateTime           @default(now()) @map("created_at")
  community    Community          @relation(fields: [communityId], references: [id], onDelete: Cascade)
  createdBy    User?              @relation(fields: [createdById], references: [id])
  rsvps        Rsvp[]
  joinRequests EventJoinRequest[]

  @@index([communityId])
  @@index([isPublic])
  @@map("events")
}

model EventJoinRequest {
  id          String              @id @default(uuid())
  eventId     String              @map("event_id")
  communityId String              @map("community_id")
  userId      String              @map("user_id")
  status      JoinRequestStatus   @default(pending)
  note        String?
  createdAt   DateTime            @default(now()) @map("created_at")
  event       Event               @relation(fields: [eventId], references: [id], onDelete: Cascade)
  community   Community           @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([communityId])
  @@index([userId])
  @@map("event_join_requests")
}

model Rsvp {
  id          String     @id @default(uuid())
  communityId String     @map("community_id")
  eventId     String     @map("event_id")
  memberId    String     @map("member_id")
  status      RsvpStatus @default(maybe)
  createdAt   DateTime   @default(now()) @map("created_at")
  community   Community  @relation(fields: [communityId], references: [id], onDelete: Cascade)
  event       Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  member      User       @relation(fields: [memberId], references: [id])

  @@unique([eventId, memberId])
  @@index([eventId])
  @@map("rsvps")
}

enum UserRole {
  admin
  member
}

enum MembershipStatus {
  active
  invited
  inactive
}


enum PocketType {
  KAS
  ARISAN
  IURAN
  PATUNGAN
}

enum TxnDirection {
  in
  out
}

enum TxnStatus {
  confirmed
  pending
}

enum ContributionStatus {
  unpaid
  pending_verify
  paid
  late
}

enum ArisanStatus {
  open
  drawn
  closed
}

enum RsvpStatus {
  yes
  no
  maybe
}

enum PaymentMethod {
  manual_transfer
  gateway
}

enum PaymentProvider {
  midtrans
  xendit
}

enum JoinRequestStatus {
  pending
  accepted
  rejected
}

enum TopUpStatus {
  pending
  paid
  failed
}

enum WithdrawalStatus {
  pending
  approved
  rejected
  transferred
}
